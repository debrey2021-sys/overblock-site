---
const faqs = [
  {
    q: 'What is overblock pay?',
    a: "Overblock pay is the extra compensation airline pilots earn when actual block time runs past scheduled block time. OverBlock shows exactly what that time is worth in real time."
  },
  {
    q: 'Who is OverBlock for?',
    a: 'OverBlock is built for airline pilots who want a faster, clearer way to track overblock earnings without doing manual math during a trip.'
  },
  {
    q: 'Do I need to create an account?',
    a: 'No. There is no sign-in, no profile, and no registration flow. Open the app, enter your details, and start a session.'
  },
  {
    q: 'Is my pay data private and secure?',
    a: 'Yes. Your rate and session data stay on your device. OverBlock does not send your pay information to any server.'
  },
  {
    q: 'Does it work for a full crew, not just me?',
    a: 'Yes. OverBlock can track both Captain and First Officer earnings together so the full crew total stays visible at a glance.'
  },
  {
    q: 'How quickly can I start using it?',
    a: 'Usually in under a minute. Enter your role, hourly rate, and scheduled block time, then tap Start Session.'
  },
  {
    q: 'Is it really free?',
    a: 'Yes. OverBlock is free to download and use. No ads, no subscription, and no in-app purchases.'
  }
];
---

<section class="faq" id="faq">
  <div class="faq-inner">
    <div class="faq-head fade-up">
      <p class="eyebrow">FAQ</p>
      <h2>Common questions</h2>
    </div>

    <ul class="faq-list">
      {faqs.map((item, index) => (
        <li class="faq-item fade-up" style={`transition-delay: ${index * 45}ms`}>
          <button class="faq-question" type="button" aria-expanded="false">
            <span>{item.q}</span>
            <span class="chevron" aria-hidden="true"></span>
          </button>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-question').forEach((button) => {
    button.addEventListener('click', () => {
      const isOpen = button.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('.faq-question').forEach((item) => {
        item.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

<style>
  .faq {
    padding: var(--section-pad) 24px;
    background: var(--color-bg);
  }

  .faq-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-head {
    margin-bottom: 32px;
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: 16px;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .faq-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 22px 0;
    background: none;
    border: 0;
    cursor: pointer;
    text-align: left;
    color: var(--color-text);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .chevron {
    width: 12px;
    height: 12px;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: rotate(45deg);
    transition: transform 200ms ease;
    flex-shrink: 0;
    margin-right: 4px;
  }

  .faq-question[aria-expanded='true'] .chevron {
    transform: rotate(225deg);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-question[aria-expanded='true'] + .faq-answer {
    grid-template-rows: 1fr;
  }

  .faq-answer p {
    min-height: 0;
    padding: 0 0 22px;
    color: var(--color-text-muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }
</style>
