---
import { APP_STORE_URL } from '../config';

const links = [
  { href: '#features', label: 'Features' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#privacy', label: 'Privacy' },
  { href: '#faq', label: 'FAQ' }
];
---

<nav class="nav" id="site-nav">
  <div class="nav-shell">
    <a href="/" class="nav-logo">OVERBLOCK</a>

    <ul class="nav-links" aria-label="Primary">
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>

    <a href={APP_STORE_URL} class="nav-cta" aria-label="Download OverBlock on the App Store">
      <svg class="nav-cta-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M15.7 12.6c0-2 1.6-3 1.7-3.1-1-.6-2.4-.7-2.9-.7-1.2-.1-2.3.7-2.9.7-.6 0-1.5-.7-2.5-.6-1.3 0-2.5.8-3.1 1.9-1.3 2.3-.3 5.7.9 7.4.6.8 1.3 1.7 2.2 1.6.9 0 1.2-.6 2.3-.6 1 0 1.3.6 2.3.6 1 0 1.6-.8 2.2-1.6.7-.9 1-1.8 1-1.9-.1 0-1.9-.8-1.9-3.7zM13.9 7.7c.5-.6.9-1.4.8-2.2-.7 0-1.6.5-2.1 1.1-.5.5-.9 1.4-.8 2.1.8.1 1.6-.4 2.1-1z" fill="currentColor"/>
      </svg>
      <span>Download on the App Store</span>
    </a>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav-drawer" id="nav-drawer">
    <ul>
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <a href={APP_STORE_URL} class="nav-cta nav-cta-mobile">
      <svg class="nav-cta-icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M15.7 12.6c0-2 1.6-3 1.7-3.1-1-.6-2.4-.7-2.9-.7-1.2-.1-2.3.7-2.9.7-.6 0-1.5-.7-2.5-.6-1.3 0-2.5.8-3.1 1.9-1.3 2.3-.3 5.7.9 7.4.6.8 1.3 1.7 2.2 1.6.9 0 1.2-.6 2.3-.6 1 0 1.3.6 2.3.6 1 0 1.6-.8 2.2-1.6.7-.9 1-1.8 1-1.9-.1 0-1.9-.8-1.9-3.7zM13.9 7.7c.5-.6.9-1.4.8-2.2-.7 0-1.6.5-2.1 1.1-.5.5-.9 1.4-.8 2.1.8.1 1.6-.4 2.1-1z" fill="currentColor"/>
      </svg>
      <span>Download on the App Store</span>
    </a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.querySelector('.nav-toggle');
  const drawer = document.getElementById('nav-drawer');

  const syncNavState = () => {
    nav?.classList.toggle('scrolled', window.scrollY > 24);
  };

  syncNavState();
  window.addEventListener('scroll', syncNavState, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    drawer?.classList.toggle('open');
  });

  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      drawer.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(250, 251, 252, 0.97);
    border-bottom: 1px solid rgba(228, 234, 240, 0.95);
    transition: background 180ms ease, box-shadow 180ms ease;
  }

  .nav.scrolled {
    background: rgba(250, 251, 252, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(10, 15, 30, 0.04);
  }

  .nav-shell {
    position: relative;
    max-width: min(1400px, calc(100vw - 64px));
    margin: 0 auto;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-logo {
    font-weight: 800;
    font-size: 1.92rem;
    color: var(--color-text);
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .nav-links {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    list-style: none;
    gap: 62px;
  }

  .nav-links a {
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--color-text);
    transition: color 150ms ease;
  }

  .nav-links a:hover {
    color: var(--color-accent-hover);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(180deg, #11cfa0, #09ba90);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 15px 22px;
    border-radius: 999px;
    line-height: 1;
    box-shadow: 0 14px 28px rgba(0, 200, 150, 0.16);
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }

  .nav-cta:hover {
    background: linear-gradient(180deg, #12d6a6, #08b186);
    transform: translateY(-1px);
  }

  .nav-cta-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    padding: 6px;
    margin-left: auto;
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text);
  }

  .nav-toggle span + span {
    margin-top: 5px;
  }

  .nav-drawer {
    display: none;
    max-width: min(1400px, calc(100vw - 64px));
    margin: 0 auto 18px;
    padding: 0 0 18px;
  }

  .nav-drawer.open {
    display: block;
  }

  .nav-drawer ul {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    padding: 18px 0 20px;
  }

  .nav-drawer a {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 600;
  }

  .nav-cta-mobile {
    display: inline-flex;
    align-items: center;
  }

  @media (max-width: 1024px) {
    .nav-links,
    .nav-shell > .nav-cta {
      display: none;
    }

    .nav-toggle {
      display: block;
    }

    .nav-shell {
      height: 84px;
    }
  }

  @media (max-width: 640px) {
    .nav-shell,
    .nav-drawer {
      max-width: calc(100vw - 32px);
    }

    .nav-shell {
      height: 76px;
    }

    .nav-logo {
      font-size: 1.56rem;
    }

    .nav-cta {
      font-size: 0.9rem;
      padding: 14px 18px;
    }
  }
</style>
